{
  "name": "headhunter-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "build:cloudflare": "next build && npx @opennextjs/cloudflare build",
    "start": "next start",
    "lint": "next lint",
    "preview": "npm run build:cloudflare && npx wrangler dev",
    "deploy": "npm run build:cloudflare && npx wrangler deploy",
    "upload": "npm run build:cloudflare && npx wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.8",
    "lucide-react": "^0.417.0",
    "next": "^15.5.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "wrangler": "^4.107.0"
  }
}